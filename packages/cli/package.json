{
  "name": "@dhruv2mars/relunar",
  "version": "0.1.1",
  "description": "CLI-first GitHub issue repro harness for coding agents",
  "type": "module",
  "bin": {
    "relunar": "dist/index.js"
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build src/index.ts --target=node --format=esm --banner '#!/usr/bin/env node' --outfile dist/index.js && chmod +x dist/index.js",
    "dev": "bun src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepack": "bun run build"
  },
  "keywords": [
    "github",
    "issues",
    "repro",
    "cli",
    "coding-agents",
    "daytona"
  ],
  "homepage": "https://github.com/Dhruv2mars/relunar#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dhruv2mars/relunar.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/Dhruv2mars/relunar/issues"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "preferGlobal": true,
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@daytona/sdk": "^0.192.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
