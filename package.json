{
  "name": "relunar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev:api": "bun --watch src/api.ts",
    "dev:worker": "bun --watch src/worker.ts",
    "start:api": "bun src/api.ts",
    "start:worker": "bun src/worker.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "smoke:e2e": "bun src/scripts/e2e-smoke.ts",
    "verify": "bun test && bun run typecheck"
  },
  "dependencies": {
    "@daytona/sdk": "^0.192.0",
    "@octokit/app": "^16.1.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.27",
    "pg-boss": "^12.23.1",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3"
  }
}
