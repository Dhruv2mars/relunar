{
  "name": "relunar-repo",
  "version": "0.1.4",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "engines": {
    "node": ">=22.12.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "verify": "turbo run test typecheck build",
    "release:trust": "npx npm@11.17.0 trust github @dhruv2mars/relunar --file release.yml --repo Dhruv2mars/relunar --allow-publish --yes",
    "release:tag": "node scripts/release-tag.mjs"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "turbo": "^2.8.4",
    "typescript": "^6.0.3"
  }
}
